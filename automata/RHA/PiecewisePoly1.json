{
  "automaton": {
    "var": "x1, x2",
    "mode": [
      {
        "id": 1,
        "eq": "x1[1] = -7, x2[1] = -x1[0]"
      },
      {
        "id": 2,
        "eq": "x1[1] = 0.5 * x1[0]**2 + 0.5 * x2[0], x2[1] = -9 * x1[0] + 3"
      },
      {
        "id": 3,
        "eq": "x1[1] = 5, x2[1] = -0.1 * x1[0] - 10"
      }
    ],
    "edge": [
      {
        "direction": "1 -> 2",
        "condition": "x2 <= 0 and x1 >= 0"
      },
      {
        "direction": "1 -> 3",
        "condition": "x2 <= 0 and x1 < 0"
      },
      {
        "direction": "2 -> 1",
        "condition": "x2 >= 0"
      },
      {
        "direction": "2 -> 3",
        "condition": "x1 <= 0"
      },
      {
        "direction": "3 -> 1",
        "condition": "x2 >= 0"
      },
      {
        "direction": "3 -> 2",
        "condition": "x1 >= 0"
      }
    ]
  },
  "init_state": [
    {"mode": 1, "x1": [1.2], "x2": [1.5]},
    {"mode": 1, "x1": [1.8], "x2": [1.1]},
    {"mode": 1, "x1": [1.5], "x2": [1.8]},
    {"mode": 1, "x1": [1.0], "x2": [1.3]},
    {"mode": 1, "x1": [1.6], "x2": [1.6]},
    {"mode": 1, "x1": [1.3], "x2": [1.9]},

    {"mode": 1, "x1": [1.4], "x2": [1.2]},
    {"mode": 1, "x1": [1.9], "x2": [1.4]},
    {"mode": 1, "x1": [1.1], "x2": [1.7]},
    {"mode": 1, "x1": [1.7], "x2": [1.0]},
    {"mode": 1, "x1": [1.25], "x2": [1.55]},
    {"mode": 1, "x1": [1.45], "x2": [1.85]},
    {"mode": 1, "x1": [1.65], "x2": [1.35]},
    {"mode": 1, "x1": [1.85], "x2": [1.65]},
    {"mode": 1, "x1": [1.35], "x2": [1.45]}
  ],
  "config": {
    "dt": 0.001,
    "total_time": 2.0,
    "order": 1,
    "other_items": "x[?] ** 2; x[?] * x_[?]",
    "kernel": "rbf"
  }
}
