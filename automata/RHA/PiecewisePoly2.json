{
  "automaton": {
    "var": "x1, x2, x3, x4",
    "mode": [
      {
        "id": 1,
        "eq": "x1[1] = -x2[0], x2[1] = x1[0] - 5, x3[1] = x4[0], x4[1] = -0.1 * (x3[0] + 5)**2"
      },
      {
        "id": 2,
        "eq": "x1[1] = -x2[0], x2[1] = x1[0] - 5, x3[1] = x4[0], x4[1] = -0.1 * (x1[0] - x3[0])**2"
      }
    ],
    "edge": [
      {
        "direction": "1 -> 2",
        "condition": "x3 >= 0"
      },
      {
        "direction": "2 -> 1",
        "condition": "x3 <= 0"
      }
    ]
  },
  "init_state": [
    {"mode": 1, "x1": [0.5], "x2": [-0.3], "x3": [-2.0], "x4": [0.8]},
