    {"mode": 1, "x1": [0.2], "x2": [0.8], "x3": [-1.0], "x4": [1.2]},
    {"mode": 2, "x1": [-0.5], "x2": [-0.7], "x3": [0.5], "x4": [-0.5]},
    {"mode": 1, "x1": [0.9], "x2": [0.1], "x3": [-2.5], "x4": [0.5]},
    {"mode": 1, "x1": [-0.3], "x2": [-0.9], "x3": [-0.5], "x4": [1.0]},

    {"mode": 2, "x1": [0.7], "x2": [0.3], "x3": [1.0], "x4": [-0.3]},
    {"mode": 1, "x1": [-0.6], "x2": [0.6], "x3": [-1.5], "x4": [0.9]},
    {"mode": 2, "x1": [0.3], "x2": [-0.5], "x3": [0.8], "x4": [0.1]},
    {"mode": 1, "x1": [0.8], "x2": [-0.2], "x3": [-2.8], "x4": [0.6]},
    {"mode": 1, "x1": [-0.1], "x2": [0.4], "x3": [-0.8], "x4": [1.4]},
    {"mode": 2, "x1": [0.4], "x2": [0.7], "x3": [1.8], "x4": [-0.2]},
    {"mode": 1, "x1": [-0.9], "x2": [-0.4], "x3": [-1.8], "x4": [0.4]},
    {"mode": 2, "x1": [0.1], "x2": [-0.8], "x3": [0.3], "x4": [0.7]},
    {"mode": 1, "x1": [0.6], "x2": [0.2], "x3": [-2.2], "x4": [1.1]}
  ],
  "config": {
    "dt": 0.001,
    "total_time": 2.0,
    "order": 1,
    "other_items": "x[?] ** 2; x[?] * x_[?]",
    "kernel": "rbf"
  }
}
