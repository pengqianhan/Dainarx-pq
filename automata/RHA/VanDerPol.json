{
  "automaton": {
    "var": "x1, x2",
    "mode": [
      {
        "id": 1,
        "eq": "x1[1] = x2[0], x2[1] = (1 - x1[0]**2) * x2[0] - x1[0]"
      }
    ],
    "edge": []
  },
  "init_state": [
    {"mode": 1, "x1": [2.5], "x2": [-1.0]},
    {"mode": 1, "x1": [-1.5], "x2": [2.0]},
    {"mode": 1, "x1": [1.0], "x2": [1.5]},
    {"mode": 1, "x1": [-2.0], "x2": [-0.5]},
    {"mode": 1, "x1": [0.5], "x2": [-2.5]},
    {"mode": 1, "x1": [-0.8], "x2": [1.2]},

    {"mode": 1, "x1": [2.0], "x2": [0.5]},
    {"mode": 1, "x1": [-2.5], "x2": [1.0]},
    {"mode": 1, "x1": [1.5], "x2": [-1.5]},
    {"mode": 1, "x1": [-1.0], "x2": [-2.0]},
    {"mode": 1, "x1": [0.3], "x2": [2.8]},
    {"mode": 1, "x1": [-0.5], "x2": [-1.8]},
    {"mode": 1, "x1": [1.8], "x2": [2.2]},
    {"mode": 1, "x1": [-2.2], "x2": [-1.2]},
    {"mode": 1, "x1": [0.8], "x2": [-0.3]}
  ],
  "config": {
    "dt": 0.01,
    "total_time": 6.0,
    "order": 1,
    "other_items": "x[?] ** 2 * x_[?]",
    "kernel": "rbf"
  }
}
